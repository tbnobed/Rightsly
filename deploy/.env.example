# Copy to deploy/.env and fill in. docker compose reads this automatically.

# --- Database ---
# Use only URL-safe characters in the password (letters, digits, - _ .),
# or set DATABASE_URL below with the password percent-encoded.
POSTGRES_DB=rightsly
POSTGRES_USER=rightsly
POSTGRES_PASSWORD=change-me-strong-password

# Optional override — takes precedence over the composed URL above.
# Required if the password contains special characters (percent-encode them).
# DATABASE_URL=postgres://rightsly:p%40ss@db:5432/rightsly

# --- API ---
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-64-hex-chars
JWT_EXPIRES_IN=12h
LOG_LEVEL=info

# Public URL users reach the app at (used for SSO redirects and email links)
APP_BASE_URL=https://rights.example.com

# Host port the web frontend is published on
WEB_PORT=8081

# --- Authentik SSO (optional — leave blank to disable) ---
AUTHENTIK_ISSUER_URL=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
SSO_AUTO_PROVISION=false
SSO_ALLOWED_DOMAINS=

# --- Seeding ---
# The seed runs on every `docker compose up` but only inserts data when the
# database is empty. Optional overrides for the initial admin account:
# ADMIN_EMAIL=admin@tbn.org
# ADMIN_PASSWORD=Admin1234!
# DANGER: SEED_FORCE=true wipes ALL data and re-seeds on next up. Keep false.
SEED_FORCE=false

# Set to true to also seed sample partners/content/contracts/revenue (demo data).
# Default: only user accounts are seeded.
SEED_DEMO_DATA=false

# --- SendGrid email (optional — leave blank to disable) ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
